<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — Attendance Scanner (JIL Antipolo)
  Flow: Select Sunday + Service → Tap SCAN → CameraActivity
        → Backend /scan → ReviewActivity (edit + export)

  This screen is ONLY for session setup.
  No thumbnail grid here — that lives in ReviewActivity.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="100dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_dark"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:elevation="4dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="#FF1E88E5"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_camera"
                        android:tint="@android:color/white"
                        android:contentDescription="App icon" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendance Scanner"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jesus Is Lord Church · Antipolo"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#FF2A2A3D" />

            <!-- ══ BADGE CHIPS ══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/chipSunday"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/chip_blue_bg"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="1st Sunday"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chipService"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/chip_green_bg"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Select a service"
                    android:textColor="@android:color/white"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ══ SELECT SUNDAY CARD ═══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELECT SUNDAY"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="5">

                        <Button android:id="@+id/btn1stSunday" style="@style/SundayButton"
                            android:layout_weight="1" android:text="1ST" />
                        <Button android:id="@+id/btn2ndSunday" style="@style/SundayButton"
                            android:layout_weight="1" android:text="2ND" />
                        <Button android:id="@+id/btn3rdSunday" style="@style/SundayButton"
                            android:layout_weight="1" android:text="3RD" />
                        <Button android:id="@+id/btn4thSunday" style="@style/SundayButton"
                            android:layout_weight="1" android:text="4TH" />
                        <Button android:id="@+id/btn5thSunday" style="@style/SundayButton"
                            android:layout_weight="1" android:text="5TH" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ SELECT SERVICE CARD ══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELECT SERVICE"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="10dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button android:id="@+id/btn1stService" style="@style/ServiceButton"
                            android:layout_weight="1" android:text="1st Service · 7:30am" />
                        <Button android:id="@+id/btn2ndService" style="@style/ServiceButton"
                            android:layout_weight="1" android:text="2nd Service · 9:00am" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvSelectionHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="⚠ Please select both a Sunday and a Service to enable scanning."
                        android:textColor="#FFFFB74D"
                        android:textSize="11sp"
                        android:visibility="visible" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ STATS ROW ════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                android:weightSum="2">

                <!-- Session card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardBackgroundColor="@color/stats_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SESSION"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12" />
                        <TextView
                            android:id="@+id/tvSessionMonth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                        <TextView
                            android:id="@+id/tvSessionWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select a session"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Sunday card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardBackgroundColor="@color/stats_card"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SELECTED"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12" />
                        <TextView
                            android:id="@+id/tvSelectedSunday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1st"
                            android:textColor="@color/accent_blue"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />
                        <TextView
                            android:id="@+id/tvSelectedService"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No service selected"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ══ INSTRUCTIONS CARD ════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/stats_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOW TO SCAN"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.  Select the Sunday and Service above"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.  Tap 📷 to open the scanner"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.  Align the sheet — tap SCAN"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.  Review &amp; edit the detected data"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.  Export as CSV"
                        android:textColor="@color/accent_green"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══ FAB STACK (bottom-right) ════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Gallery FAB (mini) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabGallery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="Choose from Gallery"
            android:src="@android:drawable/ic_menu_gallery"
            app:backgroundTint="@color/card_dark"
            app:tint="@color/accent_blue"
            app:fabSize="mini"
            app:elevation="6dp"
            app:strokeColor="@color/accent_blue"
            app:strokeWidth="1dp" />

        <!-- Enhance FAB (mini) — CamScanner-style enhancement + download -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabEnhance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="Enhance document image"
            android:src="@android:drawable/ic_menu_edit"
            app:backgroundTint="@color/card_dark"
            app:tint="#FFFF9800"
            app:fabSize="mini"
            app:elevation="6dp"
            app:strokeColor="#FFFF9800"
            app:strokeWidth="1dp" />

        <!-- Camera FAB (blue) — opens CameraActivity → /scan → ReviewActivity -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Scan attendance sheet"
            android:src="@android:drawable/ic_menu_camera"
            app:backgroundTint="@color/accent_blue"
            app:tint="@android:color/white"
            app:elevation="8dp"
            android:enabled="false" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>