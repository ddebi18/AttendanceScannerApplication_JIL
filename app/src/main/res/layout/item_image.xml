<?xml version="1.0" encoding="utf-8"?>
<!--
  item_image.xml
  A single thumbnail card displayed in the RecyclerView grid.

  Contains:
    • 96×96dp thumbnail (ImageView, loaded by Glide)
    • Badge "#N" — top-left corner
    • Red "×" remove button — top-right corner
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp">

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@color/card_dark">

        <!-- Thumbnail image -->
        <ImageView
            android:id="@+id/imgThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Attendance sheet thumbnail" />

    </androidx.cardview.widget.CardView>

    <!-- Badge "#N" — top-left -->
    <TextView
        android:id="@+id/tvBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:layout_gravity="top|start"
        android:background="@drawable/badge_bg"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:text="#1"
        android:textColor="@android:color/white"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- Remove "×" button — top-right -->
    <ImageButton
        android:id="@+id/btnRemove"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:background="@drawable/remove_button_bg"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@android:color/white"
        android:padding="3dp"
        android:contentDescription="Remove image" />

</FrameLayout>
