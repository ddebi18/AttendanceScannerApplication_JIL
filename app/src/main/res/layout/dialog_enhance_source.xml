<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_enhance_source.xml
  Lets the user choose Camera or Gallery as the image source
  for the CamScanner-style enhancement feature.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enhance Document"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose an image source to enhance"
        android:textColor="#FF9E9E9E"
        android:textSize="13sp"
        android:layout_marginBottom="20dp" />

    <!-- Camera button -->
    <Button
        android:id="@+id/btnEnhanceCamera"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="📷  Camera"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#FF1E88E5"
        android:layout_marginBottom="10dp" />

    <!-- Gallery button -->
    <Button
        android:id="@+id/btnEnhanceGallery"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="🖼  Gallery"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#FF2A2A3D" />

</LinearLayout>
