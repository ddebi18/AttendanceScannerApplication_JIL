<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="32dp"
    android:paddingBottom="28dp"
    android:gravity="center_horizontal">

    <!-- Top row: small spinner + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:indeterminate="true"
            app:indicatorColor="#FF1E88E5"
            app:trackColor="#22FFFFFF"
            app:indicatorSize="28dp"
            app:trackThickness="3dp"
            android:layout_marginEnd="14dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Processing Images"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBatchStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Uploading to server…"
                android:textColor="#FF9E9E9E"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/batchProgressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="false"
        android:progress="0"
        android:max="100"
        app:indicatorColor="#FF4CAF50"
        app:trackColor="#22FFFFFF"
        app:trackThickness="6dp"
        app:trackCornerRadius="3dp"
        android:layout_marginBottom="12dp" />

    <!-- X of N counter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/tvBatchCounter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Image 1 of …"
            android:textColor="#FF9E9E9E"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvBatchPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#FF1E88E5"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginBottom="16dp" />

    <!-- Gemini badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textColor="#FF1E88E5"
            android:textSize="12sp"
            android:layout_marginEnd="5dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by Gemini AI"
            android:textColor="#884DB6E7"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
