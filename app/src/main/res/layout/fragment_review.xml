<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_review.xml
  Layout for a single session's review UI inside the BatchReview tab.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Banner for flagged rows -->
        <LinearLayout
            android:id="@+id/bannerFlagged"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#33FFEB3B"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvBannerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Some names need review"
                android:textColor="#FBC02D"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Column Headers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@color/card_dark">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="LAST NAME"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="FIRST NAME"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="NET"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Dynamic attendance header -->
            <TextView
                android:id="@+id/tvAttHeader"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="ATT"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center" />
            <View
                android:layout_width="32dp"
                android:layout_height="0dp" />
        </LinearLayout>
        
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2A2A3D" />

        <!-- RecyclerView for rows -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/reviewRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No members scanned"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + Add Member to add manually"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Action Buttons (Bottom Left & Right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:padding="16dp"
        android:clipToPadding="false">

        <Button
            android:id="@+id/btnPurgeDeleted"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove Deleted"
            android:textColor="@color/row_deleted"
            android:visibility="gone" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddRow"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Add Member"
            android:textColor="@color/accent_blue"
            app:strokeColor="@color/accent_blue"
            app:cornerRadius="20dp" />
    </LinearLayout>

</FrameLayout>
