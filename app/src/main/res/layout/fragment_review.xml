<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_review.xml
  Layout for a single session's review UI inside the BatchReview tab.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Banner for flagged rows -->
        <LinearLayout
            android:id="@+id/bannerFlagged"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#33FFEB3B"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvBannerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Some names need review"
                android:textColor="#FBC02D"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Search Bar -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_dark"
            app:queryHint="Search names..."
            app:iconifiedByDefault="false"
            android:layout_marginBottom="2dp" />

        <!-- Column Headers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@color/card_dark">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.2"
                android:text="LAST NAME"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.5"
                android:text="FIRST NAME"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.0"
                android:text="NET"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Dynamic attendance header -->
            <TextView
                android:id="@+id/tvAttHeader"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="ATT"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:textStyle="bold"
                android:gravity="center" />
            <View
                android:layout_width="40dp"
                android:layout_height="0dp" />
        </LinearLayout>
        
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF2A2A3D" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <!-- RecyclerView for rows -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/reviewRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="80dp"
                android:paddingEnd="30dp" />

            <com.example.attendacejil.AlphabetIndexScroller
                android:id="@+id/alphabetScroller"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:layout_marginEnd="2dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabAddMember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="48dp"
                android:layout_marginBottom="24dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="@android:color/white"
                app:backgroundTint="@color/accent_blue"
                android:contentDescription="Add Member" />
        </FrameLayout>

    </LinearLayout>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No members scanned"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + Add Member to add manually"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Action Buttons (Bottom Left & Right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:padding="16dp"
        android:clipToPadding="false">

        <Button
            android:id="@+id/btnPurgeDeleted"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove Deleted"
            android:textColor="@color/row_deleted"
            android:visibility="gone" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Space
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1" />
    </LinearLayout>

</FrameLayout>
