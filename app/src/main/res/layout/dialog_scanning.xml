<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="36dp"
    android:paddingBottom="28dp"
    android:gravity="center_horizontal">

    <!-- Spinning ring + doc icon stacked -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/scanProgress"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:indeterminate="true"
            app:indicatorColor="#FF1E88E5"
            app:trackColor="#22FFFFFF"
            app:indicatorSize="80dp"
            app:trackThickness="5dp" />

        <!-- Inner circle background -->
        <View
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_inner_bg" />

        <!-- Document icon centered in ring -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="📄"
            android:textSize="24sp" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scanning Attendance Sheet"
        android:textColor="#FFFFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:gravity="center" />

    <!-- Animated status line -->
    <TextView
        android:id="@+id/tvScanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enhancing image…"
        android:textColor="#FF9E9E9E"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"
        android:layout_marginBottom="16dp" />

    <!-- Gemini badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textColor="#FF1E88E5"
            android:textSize="12sp"
            android:layout_marginEnd="5dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powered by Gemini AI"
            android:textColor="#884DB6E7"
            android:textSize="11sp"
            android:letterSpacing="0.04" />
    </LinearLayout>

</LinearLayout>
